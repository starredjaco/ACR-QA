            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h3 id=\"benchmark-results-v380\">Benchmark Results (v3.8.0)</h3>\n<table>\n<thead>\n<tr>\n<th>Metric</th>\n<th>Value</th>\n<th>Target</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td>Flask app recall</td>\n<td><strong>98.0%</strong></td>\n<td>\u2265 80%</td>\n</tr>\n<tr>\n<td>httpx recall</td>\n<td><strong>97.7%</strong></td>\n<td>\u2265 80%</td>\n</tr>\n<tr>\n<td>False-positive rate</td>\n<td><strong>1.0%</strong></td>\n<td>\u2264 5%</td>\n</tr>\n<tr>\n<td>Triage FP reduction</td>\n<td><strong>-43%</strong></td>\n<td>\u2014</td>\n</tr>\n<tr>\n<td>Scan latency (50k LOC)</td>\n<td><strong>&lt; 8s</strong></td>\n<td>&lt; 10s</td>\n</tr>\n<tr>\n<td>Total tests</td>\n<td><strong>2,170</strong></td>\n<td>\u2265 2,000</td>\n</tr>\n<tr>\n<td>Test coverage</td>\n<td><strong>89%</strong></td>\n<td>\u2265 85%</td>\n</tr>\n</tbody>\n</table>\n<blockquote>\n<span class=\"paragraph\">Benchmarked against: DVWA, DVPWA, PyGoat, Juice Shop, DVNA,\nNodeGoat, Tiredful-API, bandit-test-cases, vulnerable-flask-app, seeded-repo</span>\n</blockquote></span>"
