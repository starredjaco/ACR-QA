{
    "__inputs": [],
    "__requires": [
        {
            "type": "panel",
            "id": "timeseries",
            "name": "Time series",
            "version": ""
        },
        {
            "type": "panel",
            "id": "gauge",
            "name": "Gauge",
            "version": ""
        },
        {
            "type": "panel",
            "id": "stat",
            "name": "Stat",
            "version": ""
        },
        {
            "type": "datasource",
            "id": "prometheus",
            "name": "Prometheus",
            "version": ""
        }
    ],
    "description": "ACR-QA monitoring dashboard — HTTP traffic, latency, and analysis throughput",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "id": 1,
            "type": "timeseries",
            "title": "🌐 Request Rate (req/s)",
            "description": "HTTP requests per second to the ACR-QA Flask API, broken down by endpoint",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "rate(acrqa_http_requests_total[5m])",
                    "legendFormat": "{{endpoint}} ({{method}})",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "reqps",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10
                    }
                }
            },
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "calcs": [
                        "mean",
                        "max"
                    ]
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "desc"
                }
            }
        },
        {
            "id": 2,
            "type": "timeseries",
            "title": "⏱️ API Response Time P95 (ms)",
            "description": "95th-percentile latency per endpoint — alerts if above 2s",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, rate(acrqa_http_request_duration_seconds_bucket[5m])) * 1000",
                    "legendFormat": "P95 {{endpoint}}",
                    "refId": "A"
                },
                {
                    "expr": "histogram_quantile(0.50, rate(acrqa_http_request_duration_seconds_bucket[5m])) * 1000",
                    "legendFormat": "P50 {{endpoint}}",
                    "refId": "B"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "ms",
                    "custom": {
                        "lineWidth": 2
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 500
                            },
                            {
                                "color": "red",
                                "value": 2000
                            }
                        ]
                    }
                }
            },
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "calcs": [
                        "mean",
                        "max"
                    ]
                },
                "tooltip": {
                    "mode": "multi",
                    "sort": "desc"
                }
            }
        },
        {
            "id": 3,
            "type": "stat",
            "title": "📊 Total API Requests (All Time)",
            "description": "Cumulative count of all HTTP requests since server start",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "sum(acrqa_http_requests_total)",
                    "legendFormat": "Total Requests",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "unit": "short",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "blue",
                                "value": null
                            }
                        ]
                    }
                }
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "area",
                "justifyMode": "center"
            }
        },
        {
            "id": 4,
            "type": "stat",
            "title": "✅ HTTP 200 Success Rate",
            "description": "Percentage of successful (2xx) responses",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 6,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "sum(rate(acrqa_http_requests_total{status_code=~\"2..\"}[5m])) / sum(rate(acrqa_http_requests_total[5m])) * 100",
                    "legendFormat": "Success %",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "unit": "percent",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 90
                            },
                            {
                                "color": "green",
                                "value": 99
                            }
                        ]
                    },
                    "min": 0,
                    "max": 100
                }
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "center"
            }
        },
        {
            "id": 5,
            "type": "gauge",
            "title": "🧠 LLM Explanation Latency (avg ms)",
            "description": "Average time to generate one AI explanation via Groq API",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "rate(acrqa_http_request_duration_seconds_sum{endpoint=~\".*/explain.*\"}[5m]) / rate(acrqa_http_request_duration_seconds_count{endpoint=~\".*/explain.*\"}[5m]) * 1000",
                    "legendFormat": "Avg LLM latency",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "unit": "ms",
                    "min": 0,
                    "max": 3000,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 1000
                            },
                            {
                                "color": "red",
                                "value": 2000
                            }
                        ]
                    }
                }
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "showThresholdLabels": true
            }
        },
        {
            "id": 6,
            "type": "stat",
            "title": "🔴 Error Rate (5xx/min)",
            "description": "Count of server errors in the last minute",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 18,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "expr": "sum(rate(acrqa_http_requests_total{status_code=~\"5..\"}[1m])) * 60",
                    "legendFormat": "5xx errors/min",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "unit": "short",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 1
                            },
                            {
                                "color": "red",
                                "value": 5
                            }
                        ]
                    }
                }
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "colorMode": "background",
                "graphMode": "area"
            }
        }
    ],
    "refresh": "30s",
    "schemaVersion": 38,
    "tags": [
        "acr-qa",
        "monitoring",
        "flask",
        "prometheus"
    ],
    "templating": {
        "list": []
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "timepicker": {},
    "timezone": "browser",
    "title": "ACR-QA — API Monitoring",
    "uid": "acr-qa-monitoring",
    "version": 1
}
