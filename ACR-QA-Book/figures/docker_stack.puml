@startuml docker_stack
scale 2.5
'──────────────────────────────────────────────────────────────
'  ACR-QA  v5.0.0rc2  —  Docker Compose Service Topology
'  Portrait A4 — 1 rectangle per tier = guaranteed vertical
'  7 services: api · worker · dashboard · postgres · redis
'              prometheus · grafana
'  King Salman International University · CSE494 · 2025-26
'──────────────────────────────────────────────────────────────
!theme plain
top to bottom direction

skinparam backgroundColor    #FFFFFF
skinparam defaultFontName    "Arial"
skinparam defaultFontSize    24
skinparam shadowing          false
skinparam wrapWidth          320

skinparam rectangle {
  BorderThickness  2.5
  RoundCorner      8
  FontSize         22
}
skinparam package {
  BorderThickness  2.5
  FontStyle        bold
  FontSize         24
}
skinparam arrow {
  Thickness  3.0
  Color      #002654
  FontColor  #374151
  FontSize   18
}
skinparam note {
  BackgroundColor #FFFDE7
  BorderColor     #C9A84C
  FontSize        18
}
skinparam cloud {
  BackgroundColor #F0FDF4
  BorderColor     #16A34A
  BorderThickness 2.5
  FontSize        22
}
skinparam actor {
  FontSize 22
}

actor "Developer / CI/CD / GitHub Webhook" as CLIENT

rectangle "Docker Host  ·  docker compose up -d  ·  bridge: acrqa-network" as HOST #F1F5F9 {

  package "Application Tier" as APP #DCFCE7 {
    rectangle "api :8000  (FastAPI 0.115 · 52 endpoints · JWT + API-Key)\nworker (Celery 5 · 4 concurrent · max_retries=2)" as SVC_APP #BBF7D0
  }

  package "Frontend Tier" as FE #D1FAE5 {
    rectangle "dashboard :3000  (React 18 + TypeScript · shadcn/ui · WCAG 2.1 AA)" as SVC_DASH #A7F3D0
  }

  package "Data Tier" as DATA #FEF3C7 {
    rectangle "postgres :5432  (PostgreSQL 15 · 13-table schema · 18 migrations)\nredis :6379    (Redis 7.2 · Celery broker · rate-limit token bucket)" as SVC_DB #FDE68A
  }

  package "Observability Tier" as OBS #F3F0FF {
    rectangle "prometheus :9090  (scrape every 15 s · SLO burn-rate alerts)\ngrafana :3001    (ACR-QA dashboard · Prometheus datasource)" as SVC_OBS #E9D5FF
  }

  APP  -[hidden]down-> FE
  FE   -[hidden]down-> DATA
  DATA -[hidden]down-> OBS
}

cloud "External Services" as EXT {
  rectangle "Groq API (LLaMA-3.3-70B)  ·  Ollama local (qwen2.5-coder:1.5b)\nGitHub API (PR comments + check-runs)" as EXT_SVC #DCFCE7
}

CLIENT   --> HOST    : HTTPS :8000 / :3000
HOST     --> EXT_SVC : LLM calls · PR comments

note right of HOST
  <b>Named volumes:</b>
  postgres-data · redis-data
  scan-workspace · grafana-data

  <b>Required env vars:</b>
  GROQ_API_KEY · DATABASE_URL
  REDIS_URL · SECRET_KEY
end note

@enduml
