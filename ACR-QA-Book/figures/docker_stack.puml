@startuml docker_stack
'──────────────────────────────────────────────────────────────
'  ACR-QA  v4.0.0  —  Docker Compose Stack  (A4-portrait edition)
'  Layout: top-to-bottom tiers, services grouped by role
'──────────────────────────────────────────────────────────────
!theme plain
top to bottom direction

skinparam backgroundColor    #FFFFFF
skinparam defaultFontName    "Arial"
skinparam defaultFontSize    11
skinparam shadowing          false
skinparam wrapWidth          280

skinparam rectangle {
  BorderThickness  2
  RoundCorner      8
  FontSize         10
}
skinparam package {
  BorderThickness  2
  FontStyle        bold
  FontSize         11
}
skinparam arrow {
  Thickness  1.8
  Color      #002654
  FontColor  #374151
  FontSize   9
}
skinparam note {
  BackgroundColor #FFFDE7
  BorderColor     #C9A84C
  FontSize        9
}
skinparam cloud {
  BackgroundColor #F0FDF4
  BorderColor     #16A34A
  BorderThickness 2
  FontSize        10
}

'════════════════════════════════════════════════════
'  CLIENTS (outside the stack)
'════════════════════════════════════════════════════
actor "Developer / CI/CD / GitHub Webhook" as CLIENT

'════════════════════════════════════════════════════
'  DOCKER HOST
'════════════════════════════════════════════════════
rectangle "Host  ·  docker compose up -d  ·  Bridge network: acrqa-network" as HOST #F1F5F9 {

  '── APPLICATION TIER ─────────────────────────────
  package "APPLICATION TIER" as APP #DCFCE7 {
    rectangle "api  :8000\nFastAPI 0.111 · 33 endpoints\nJWT + API-Key · Pydantic v2 · CORE pipeline" as SVC_API  #BBF7D0
    rectangle "worker  (Celery)\nCelery 5.3 · 4 concurrent workers\nscan_repository task · max_retries=2" as SVC_WRK  #A7F3D0
    SVC_API -[hidden]down-> SVC_WRK
  }

  '── FRONTEND TIER ────────────────────────────────
  package "FRONTEND TIER" as FE #D1FAE5 {
    rectangle "dashboard  :5173\nReact 18 + TypeScript · Vite 5 · shadcn/ui\nWCAG 2.1 AA · EN + AR RTL · WCAG axe-core tested" as SVC_DASH #A7F3D0
  }

  '── DATA TIER ────────────────────────────────────
  package "DATA TIER" as DATA #FEF3C7 {
    rectangle "postgres  :5432\nPostgreSQL 15 · 10-table schema · 10 Alembic migrations\nFull AI provenance · findings · llm_explanations · attestations" as SVC_PG #FDE68A
    rectangle "redis  :6379\nRedis 7.2 · Celery broker · rate-limit token bucket\nLFU eviction" as SVC_RD #FDE68A
    SVC_PG -[hidden]down-> SVC_RD
  }

  '── OBSERVABILITY TIER ───────────────────────────
  package "OBSERVABILITY TIER" as OBS #F3F0FF {
    rectangle "prometheus  :9090\nScrape /metrics every 15 s\nSLO burn-rate alerting (1h fast + 6h slow)" as SVC_PROM #E9D5FF
    rectangle "grafana  :3000\nACR-QA dashboard · alert rules\nPrometheus datasource" as SVC_GRAF #E9D5FF
    rectangle "jaeger  :16686\nOpenTelemetry distributed tracing\nSpans from api + worker containers" as SVC_JAE #E9D5FF
    SVC_PROM -[hidden]down-> SVC_GRAF
    SVC_GRAF -[hidden]down-> SVC_JAE
  }

  APP  -[hidden]down-> FE
  FE   -[hidden]down-> DATA
  DATA -[hidden]down-> OBS
}

'════════════════════════════════════════════════════
'  EXTERNAL SERVICES
'════════════════════════════════════════════════════
cloud "External Services" as EXT {
  rectangle "Groq API\nLLaMA-3.3-70B" as GROQ #DCFCE7
  rectangle "GitHub API\nPR comments + check-runs" as GH #DCFCE7
  rectangle "Sigstore / Fulcio\nOIDC keyless signing" as SIG #DCFCE7
}

'════════════════════════════════════════════════════
'  CONNECTIONS
'════════════════════════════════════════════════════
CLIENT   --> SVC_API  : HTTPS :8000
CLIENT   --> SVC_DASH : HTTPS :5173
SVC_API  --> SVC_RD   : enqueue Celery task
SVC_RD   --> SVC_WRK  : task pickup
SVC_WRK  --> SVC_PG   : persist results
SVC_API  --> SVC_PG   : read findings
SVC_PROM --> SVC_API  : scrape /metrics
SVC_PROM --> SVC_WRK  : scrape /metrics
SVC_GRAF --> SVC_PROM : datasource
SVC_API  --> SVC_JAE  : OTel spans
SVC_WRK  --> SVC_JAE  : OTel spans
SVC_DASH --> SVC_API  : REST API calls
SVC_WRK  --> GROQ     : LLM enrichment
SVC_API  --> GH       : POST check-run
SVC_API  --> SIG      : cosign keyless

note right of HOST
  <b>8 services total</b>
  Named volumes:
  postgres-data · redis-data
  scan-workspace · grafana-data

  <b>Required env vars:</b>
  GROQ_API_KEY · DATABASE_URL
  REDIS_URL · SECRET_KEY
  WEBHOOK_SECRET · OTEL_ENDPOINT
end note

@enduml
