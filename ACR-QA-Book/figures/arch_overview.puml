@startuml arch_overview
scale 2.5
'──────────────────────────────────────────────────────────────
'  ACR-QA  v5.0.0rc2  —  High-Level System Architecture
'  Portrait A4 — 6 packages × 1 rectangle each = true vertical
'  King Salman International University · CSE494 · 2025-26
'──────────────────────────────────────────────────────────────
!theme plain
top to bottom direction

skinparam backgroundColor    #FFFFFF
skinparam defaultFontName    "Arial"
skinparam defaultFontSize    12
skinparam shadowing          false
skinparam wrapWidth          260

skinparam rectangle {
  BorderThickness  2
  RoundCorner      10
  FontSize         11
}
skinparam package {
  BorderThickness  2
  FontStyle        bold
  FontSize         12
}
skinparam arrow {
  Thickness  1.8
  Color      #002654
  FontColor  #374151
  FontSize   10
}
skinparam note {
  BackgroundColor #FFFDE7
  BorderColor     #C9A84C
  FontSize        10
}

package "① CLIENTS" as T1 #DBEAFE {
  rectangle "Developer · CI/CD Pipeline · GitHub Webhook\nReact 18 Dashboard  ·  REST CLI  ·  MCP Server" as CLI #BFDBFE
}

package "② FastAPI REST  ·  52 endpoints  ·  JWT + API-Key  ·  Pydantic v2" as T2 #DCFCE7 {
  rectangle "Scan · Results · Autofix · Attestation · SARIF · Feedback\nRate-limit (Redis token bucket)  ·  RBAC (admin / analyst)" as API #BBF7D0
}

package "③ Celery Workers  ·  4 concurrent  ·  Redis broker" as T3 #E0F2FE {
  rectangle "run_analysis_pipeline(run_id)  ·  bind=True  ·  max_retries=2\nAsync execution  ·  PostgreSQL status tracking" as WRK #BAE6FD
}

package "④ 12-Stage Analysis Pipeline  ·  CORE/main.py" as T4 #FEF9C3 {
  rectangle "⓪ Rate Limit  ①Ingest  ②12-Tool Dispatch (parallel thread pool)\n③ Normalise→CanonicalFinding · Taint · Dedup · Reachability\n④ 5-Signal Confidence Scoring Cs∈[0,100]  ⑤ RAG+LLM-Aug\n⑥ SCA+CBoM  ⑦ Quality Gate  ⑧ SARIF · PDF · PR Comments" as PL #FEF3C7
}

package "⑤ 19 Engines  ·  3 Adapters  ·  66 Rules / 422 Mappings" as T5 #F0FFF4 {
  rectangle "Python: Ruff · Bandit · Semgrep · Vulture · Radon · SCA · Secrets\nJS/TS: ESLint · Semgrep · npm audit    Go: gosec · staticcheck\nv5.0: Risk Predictor · Time-Travel · IaC · PR Risk · Verified Remediation" as ENG #A7F3D0
}

package "⑥ Storage & Observability" as T6 #FFF7ED {
  rectangle "PostgreSQL 15 · 13 tables · 18 migrations · AI provenance\nRedis 7.2 (broker + rate-limit)  ·  Prometheus + Grafana (SLO)" as STO #FED7AA
}

CLI --> API  : HTTP / webhook
API --> WRK  : enqueue (Redis)
WRK --> T4   : execute pipeline
T4  --> T5   : subprocess calls
T5  --> T4   : raw findings
T4  --> STO  : persist + metrics

note right of T4
  <b>96.4%</b> Confirmed Tier precision
  <b>100%</b> CVE recall (8/8)
  F₁ = <b>98.2%</b>  vs Semgrep 45.7%
  2,897 tests · 84.89% coverage
end note

@enduml
