# ─── ACR-QA Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database (PostgreSQL) ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=acrqa
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── AI Explanations (Groq — Free Tier, Key Pool Rotation) ──────────────
# Create multiple Groq accounts for rate limit distribution.
# Get keys at: https://console.groq.com/keys
GROQ_API_KEY_1=gsk-your-key-1-here
GROQ_API_KEY_2=gsk-your-key-2-here
GROQ_API_KEY_3=gsk-your-key-3-here
GROQ_API_KEY_4=gsk-your-key-4-here

# ─── GitHub Integration (Optional) ──────────────────────────────────────
# Required for PR comment posting. Generate at: GitHub → Settings → Developer Settings → PAT
GITHUB_TOKEN=

# ─── GitLab Integration (Optional) ──────────────────────────────────────
GITLAB_TOKEN=

# ─── Gemini (Multi-LLM jury secondary provider — free tier, no card) ────
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Flask Dashboard ────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-in-production

# ─── Scanner tuning (Optional) ──────────────────────────────────────────
# Deep AST security pass — the deterministic engine behind the RealVuln results and the product's
# primary security detector. On by default; set to 0 to run only the legacy tool pass (style/quality).
ACRQA_DEEP_SCAN=1
# Per-finding enrichment budget. Taint/reachability run on the top-N findings by severity
# (ACRQA_ENRICH_CAP); Docker exploit-verification (slow, ~seconds per HIGH finding) is capped
# separately (ACRQA_EXPLOIT_CAP) and skips automatically when Docker is unavailable. Raise for
# thoroughness, lower for speed.
ACRQA_ENRICH_CAP=150
ACRQA_EXPLOIT_CAP=10
