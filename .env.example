# ─── ACR-QA Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database (PostgreSQL) ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=acrqa
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── AI Explanations (Cerebras — Free Tier) ─────────────────────────────
# Get your key at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=csk-your-key-here

# ─── GitHub Integration (Optional) ──────────────────────────────────────
# Required for PR comment posting. Generate at: GitHub → Settings → Developer Settings → PAT
GITHUB_TOKEN=

# ─── GitLab Integration (Optional) ──────────────────────────────────────
GITLAB_TOKEN=

# ─── Flask Dashboard ────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-in-production
