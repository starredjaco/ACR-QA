# ─── ACR-QA Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database (PostgreSQL) ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=acrqa
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── AI Explanations (Groq — Free Tier, Key Pool Rotation) ──────────────
# Create multiple Groq accounts for rate limit distribution.
# Get keys at: https://console.groq.com/keys
GROQ_API_KEY_1=gsk-your-key-1-here
GROQ_API_KEY_2=gsk-your-key-2-here
GROQ_API_KEY_3=gsk-your-key-3-here
GROQ_API_KEY_4=gsk-your-key-4-here

# ─── GitHub Integration (Optional) ──────────────────────────────────────
# Required for PR comment posting. Generate at: GitHub → Settings → Developer Settings → PAT
GITHUB_TOKEN=

# ─── GitLab Integration (Optional) ──────────────────────────────────────
GITLAB_TOKEN=

# ─── Flask Dashboard ────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-in-production
